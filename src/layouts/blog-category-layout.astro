---
import type { getStaticPaths } from '@/pages/[...category]/index.astro';
import BaseLayout from './base-layout.astro';
import type { InferGetStaticPropsType } from 'astro';
type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { category } = Astro.props as Props;
---
<BaseLayout
  title={category.data.title}
  description={category.data.description}
  tags={category.data.tags}
  author={category.data.author}
>
  <p>{category.data.title}</p>
  <slot />
  
  <!-- BlogList -->
  <ul>
    {category.blogs && category.blogs.map(blog => (
      <li>
        <a href={`/${blog.slug}`}>{blog.data.title}</a>
      </li>
    ))}
  </ul>
  
</BaseLayout>