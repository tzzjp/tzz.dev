---
import BaseLayout from './base-layout.astro';
const { blog } = Astro.props;
---
<BaseLayout
  title={blog.title}
  description={blog.description}
  tags={blog.tags}
  author={blog.author}
>
  <h1 class="text-center text-xl font-bold">{blog.title}</h1>
  <div class="mx-60 flex justify-between">
    <span>発表時間：{blog.pubDate}</span>
    <span>更新時間：{blog.lastModified}</span>
  </div>
  <slot />
</BaseLayout>