---
import { getCollection } from 'astro:content';
import { getGitInfo } from '@/lib/git';
import BlogLayout from '@/layouts/blog-layout.astro';

export async function getStaticPaths() {
  const blogs = (await getCollection('blog', ({id}) => !id.endsWith('index.md')));
  
  const blogsWithGitInfo = await Promise.all(
    blogs.map(async (blog) => {
      const gitInfo = await getGitInfo('./src/content/blog/' + blog.id);
      if(gitInfo === null) {
        return blog;
      } else {
        return { ...blog, data: { ...gitInfo, ...(blog.data || {}) } }
      }
    })
  );

  return blogsWithGitInfo.map(blog => ({
    params: { slug: blog.slug },
    props: { blog }
  }));
}

const { blog } = Astro.props;
const { Content } = await blog.render();
import { Debug } from 'astro:components';
---
<BlogLayout
title={blog.data.title}
description={blog.data.description}
tags={blog.data.tags}
author={blog.data.author}>
  <Debug {blog}/>
  <Content />
</BlogLayout>